{
  "name": "moya-matrix",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "moya矩阵 Electron + React shell for cloud drive and video editor modules.",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0\" \"wait-on http://127.0.0.1:5174 && electron .\"",
    "dev:renderer": "vite --host 0.0.0.0",
    "dev:electron": "wait-on http://127.0.0.1:5174 && electron .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4174",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "axios": "^1.6.2",
    "clsx": "^2.1.1",
    "electron-store": "^8.1.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.2",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "pupcaps": "^1.0.0-alpha2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.4.14",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.moya.matrix",
    "productName": "moya矩阵",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/@ffmpeg-installer/win32-x64/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "bin/ffprobe.exe"
      },
      {
        "from": "public/fonts",
        "to": "fonts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "electron/assets/app-icon.ico",
      "target": "nsis"
    }
  }
}
